---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <h1>Hey, I'm Ross.</h1>
      <p>
        I'm a software engineer based in Edinburgh, Scotland. I currently work
        at
        <a href="https://www.wordsmith.ai/">Wordsmith AI</a>, where we're
        building AI-powered tools for in-house legal teams.
      </p>
      <p>
        Before Wordsmith, I was a Staff Software Engineer at
        <a href="https://grail.com/">GRAIL</a>, working on early cancer
        detection. Prior to that I spent time at Coinbase, Conduce Group, and
        over five years at
        <a href="https://www.skyscanner.net/">Skyscanner</a>.
      </p>
      <p>
        I studied Computer Science at the University of St Andrews. I write here
        about software engineering, AI tooling, and things I find interesting.
      </p>
      <p>
        You can find me on <a
          href="https://www.linkedin.com/in/ross-conyers-55a31348/">LinkedIn</a
        >.
      </p>
    </main>
    <Footer />
  </body>
</html>
